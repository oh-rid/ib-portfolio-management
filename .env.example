# IB Flex Web Service credentials.
#
# Copy this file to `.env` and fill in the values from your IB Client Portal:
#   1. Token:   Performance & Statements → Flex Queries → Flex Web Service
#               (one token; long-lived, no 2FA).
#   2. Queries: Performance & Statements → Flex Queries → New Activity Statement.
#               Each query gets its own integer ID. Set Period = Custom Date Range
#               so the script can override dates via --from/--to or --year.
#
# IB_FLEX_QUERY_TRADES       — Activity query with the Trades section.
# IB_FLEX_QUERY_CLOSED_LOTS  — Activity query with Trades + Options → Closed Lots
#                              (required for the tax-year EUR XLSX workflow).

IB_FLEX_TOKEN=""
IB_FLEX_QUERY_TRADES=""
IB_FLEX_QUERY_CLOSED_LOTS=""
